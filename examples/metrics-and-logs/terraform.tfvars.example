subscription_id     = "your-azure-subscription-id"
location            = "eastus"
prefix              = "tsuga"
tsuga_api_key       = "your-tsuga-api-key"
tsuga_intake_url    = "https://intake.tsuga.io/v1/otlp"
collection_interval = "60s"
logs_min_replicas   = 1
logs_max_replicas   = 3

tags = {
  Environment = "production"
  ManagedBy   = "terraform"
}
